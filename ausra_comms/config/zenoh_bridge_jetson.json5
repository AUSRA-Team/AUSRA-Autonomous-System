// zenoh_bridge_jetson.json5 - Zenoh bridge config for Jetson robots.
// Only relay_node's *_relay topics and heartbeat cross WiFi.
{
  plugins: {
    ros2dds: {
      domain: 0,
      namespace: "/",
      allow: {
        publishers: [
          "/ausra_.*/map_relay",
          "/ausra_.*/pose_relay",
          "/ausra_.*/heartbeat",
        ],
        subscribers: [
          "/ausra_.*/map_relay",
          "/ausra_.*/pose_relay",
          "/ausra_.*/heartbeat",
        ],
        service_servers: [],
        service_clients: [],
        action_servers:  [],
        action_clients:  [],
      },
      reliable_routes_blocking: true,
    },
  },
  mode: "peer",
  listen: {
    endpoints: ["tcp/0.0.0.0:7447"],
  },
  scouting: {
    multicast: {
      enabled: true,
      address: "224.0.0.224:7446",
      interface: "auto",
    },
    gossip: {
      enabled: true,
    },
  },
  connect: {
    endpoints: [
      "tcp/192.168.1.33:7447",   // Jetson 1
      "tcp/192.168.1.42:7447",   // Jetson 2
      "tcp/192.168.1.34:7447",   // Laptop
    ],
  },
}