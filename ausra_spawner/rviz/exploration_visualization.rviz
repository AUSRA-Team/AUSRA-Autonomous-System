# ==============================================================================
# AUSRA Multi-Robot Exploration Visualization
# ==============================================================================
# Comprehensive RViz configuration for visualizing:
# - SLAM map building in real-time
# - Frontier exploration markers
# - Local and global costmaps
# - Path planning (local and global)
# - LiDAR scans
# - Robot models and TF frames
# - Navigation goals
# ==============================================================================

Panels:
  - Class: rviz_common/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /TF1
        - /SLAM Map1
        - /Robot 1 - Exploration1
        - /Robot 2 - Exploration1
      Splitter Ratio: 0.55
    Tree Height: 600
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Tool Properties
    Expanded:
      - /2D Goal Pose1
      - /2D Pose Estimate1
    Name: Tool Properties
    Splitter Ratio: 0.5
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz_common/Time
    Experimental: false
    Name: Time
    SyncMode: 0
    SyncSource: ""

Visualization Manager:
  Class: ""
  Displays:
    # ==========================================================================
    # BASE VISUALIZATION
    # ==========================================================================
    - Alpha: 0.3
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 80; 80; 80
      Enabled: true
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: -0.01
      Plane: XY
      Plane Cell Count: 100
      Reference Frame: <Fixed Frame>
      Value: true

    # ==========================================================================
    # TF FRAMES - All robot frames and map frame
    # ==========================================================================
    - Class: rviz_default_plugins/TF
      Enabled: true
      Frame Timeout: 15
      Frames:
        All Enabled: false
        map:
          Value: true
        ausra_1_odom:
          Value: true
        ausra_1_robot_footprint:
          Value: true
        ausra_1_base_link:
          Value: true
        ausra_1_lidar_link:
          Value: false
        ausra_2_odom:
          Value: true
        ausra_2_robot_footprint:
          Value: true
        ausra_2_base_link:
          Value: true
        ausra_2_lidar_link:
          Value: false
      Marker Scale: 0.4
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        map:
          ausra_1_odom:
            ausra_1_robot_footprint:
              ausra_1_base_link: {}
          ausra_2_odom:
            ausra_2_robot_footprint:
              ausra_2_base_link: {}
      Update Interval: 0
      Value: true

    # ==========================================================================
    # SLAM MAP - Real-time map building visualization
    # ==========================================================================
    - Alpha: 0.8
      Class: rviz_default_plugins/Map
      Color Scheme: map
      Draw Behind: true
      Enabled: true
      Name: SLAM Map
      Topic:
        Depth: 1
        Durability Policy: Transient Local
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_1/map
      Update Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_1/map_updates
      Use Timestamp: false
      Value: true

    # ==========================================================================
    # ROBOT 1 - EXPLORATION GROUP
    # ==========================================================================
    - Class: rviz_common/Group
      Displays:
        # Robot 1 Model
        - Class: rviz_default_plugins/RobotModel
          Collision Enabled: false
          Description File: ""
          Description Source: Topic
          Description Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/robot_description
          Enabled: true
          Links:
            All Links Enabled: true
          Mass Properties:
            Inertia: false
            Mass: false
          Name: Robot Model
          TF Prefix: ""
          Update Interval: 0
          Value: true
          Visual Enabled: true

        # Robot 1 LiDAR Scan
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz_default_plugins/LaserScan
          Color: 0; 255; 100
          Color Transformer: FlatColor
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 4096
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: LiDAR Scan
          Position Transformer: XYZ
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.05
          Style: Flat Squares
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Best Effort
            Value: /ausra_1/scan
          Use Fixed Frame: true
          Use rainbow: false
          Value: true

        # Robot 1 Global Costmap (for planning)
        - Alpha: 0.4
          Class: rviz_default_plugins/Map
          Color Scheme: costmap
          Draw Behind: false
          Enabled: true
          Name: Global Costmap
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/global_costmap/costmap
          Update Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/global_costmap/costmap_updates
          Use Timestamp: false
          Value: true

        # Robot 1 Local Costmap (for obstacle avoidance)
        - Alpha: 0.6
          Class: rviz_default_plugins/Map
          Color Scheme: costmap
          Draw Behind: false
          Enabled: true
          Name: Local Costmap
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/local_costmap/costmap
          Update Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/local_costmap/costmap_updates
          Use Timestamp: false
          Value: true

        # Robot 1 Global Path (planned path)
        - Alpha: 1
          Buffer Length: 1
          Class: rviz_default_plugins/Path
          Color: 0; 200; 255
          Enabled: true
          Head Diameter: 0.3
          Head Length: 0.2
          Length: 0.3
          Line Style: Lines
          Line Width: 0.04
          Name: Global Path
          Offset:
            X: 0
            Y: 0
            Z: 0.02
          Pose Color: 0; 200; 255
          Pose Style: None
          Radius: 0.03
          Shaft Diameter: 0.1
          Shaft Length: 0.1
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/plan
          Value: true

        # Robot 1 Local Path (controller trajectory)
        - Alpha: 1
          Buffer Length: 1
          Class: rviz_default_plugins/Path
          Color: 255; 150; 0
          Enabled: true
          Head Diameter: 0.15
          Head Length: 0.1
          Length: 0.15
          Line Style: Lines
          Line Width: 0.02
          Name: Local Path
          Offset:
            X: 0
            Y: 0
            Z: 0.03
          Pose Color: 255; 150; 0
          Pose Style: None
          Radius: 0.02
          Shaft Diameter: 0.05
          Shaft Length: 0.05
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/local_plan
          Value: true

        # Robot 1 Frontier Markers
        - Class: rviz_default_plugins/MarkerArray
          Enabled: true
          Name: Frontiers
          Namespaces:
            frontiers: true
            home: true
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/exploration/frontiers
          Value: true

        # Robot 1 Current Goal
        - Alpha: 1
          Axes Length: 0.3
          Axes Radius: 0.03
          Class: rviz_default_plugins/Pose
          Color: 0; 255; 0
          Enabled: true
          Head Length: 0.1
          Head Radius: 0.1
          Name: Current Goal
          Shaft Length: 0.3
          Shaft Radius: 0.05
          Shape: Arrow
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/goal_pose
          Value: true

        # Robot 1 Odometry (velocity arrows)
        - Angle Tolerance: 0.1
          Class: rviz_default_plugins/Odometry
          Covariance:
            Orientation:
              Alpha: 0.5
              Color: 255; 255; 127
              Color Style: Unique
              Frame: Local
              Offset: 1
              Scale: 1
              Value: false
            Position:
              Alpha: 0.3
              Color: 204; 51; 204
              Scale: 1
              Value: false
            Value: false
          Enabled: true
          Keep: 1
          Name: Odometry
          Position Tolerance: 0.1
          Shape:
            Alpha: 1
            Axes Length: 0.3
            Axes Radius: 0.02
            Color: 0; 255; 0
            Head Length: 0.07
            Head Radius: 0.05
            Shaft Length: 0.15
            Shaft Radius: 0.03
            Value: Arrow
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_1/odom
          Value: true

      Enabled: true
      Name: "Robot 1 - Exploration"

    # ==========================================================================
    # ROBOT 2 - EXPLORATION GROUP
    # ==========================================================================
    - Class: rviz_common/Group
      Displays:
        # Robot 2 Model
        - Class: rviz_default_plugins/RobotModel
          Collision Enabled: false
          Description File: ""
          Description Source: Topic
          Description Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/robot_description
          Enabled: true
          Links:
            All Links Enabled: true
          Mass Properties:
            Inertia: false
            Mass: false
          Name: Robot Model
          TF Prefix: ""
          Update Interval: 0
          Value: true
          Visual Enabled: true

        # Robot 2 LiDAR Scan
        - Alpha: 1
          Autocompute Intensity Bounds: true
          Autocompute Value Bounds:
            Max Value: 10
            Min Value: -10
            Value: true
          Axis: Z
          Channel Name: intensity
          Class: rviz_default_plugins/LaserScan
          Color: 255; 100; 100
          Color Transformer: FlatColor
          Decay Time: 0
          Enabled: true
          Invert Rainbow: false
          Max Color: 255; 255; 255
          Max Intensity: 4096
          Min Color: 0; 0; 0
          Min Intensity: 0
          Name: LiDAR Scan
          Position Transformer: XYZ
          Selectable: true
          Size (Pixels): 3
          Size (m): 0.05
          Style: Flat Squares
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Best Effort
            Value: /ausra_2/scan
          Use Fixed Frame: true
          Use rainbow: false
          Value: true

        # Robot 2 Global Costmap
        - Alpha: 0.3
          Class: rviz_default_plugins/Map
          Color Scheme: costmap
          Draw Behind: false
          Enabled: false
          Name: Global Costmap
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/global_costmap/costmap
          Use Timestamp: false
          Value: true

        # Robot 2 Local Costmap
        - Alpha: 0.5
          Class: rviz_default_plugins/Map
          Color Scheme: costmap
          Draw Behind: false
          Enabled: false
          Name: Local Costmap
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/local_costmap/costmap
          Use Timestamp: false
          Value: true

        # Robot 2 Global Path
        - Alpha: 1
          Buffer Length: 1
          Class: rviz_default_plugins/Path
          Color: 255; 50; 50
          Enabled: true
          Head Diameter: 0.3
          Head Length: 0.2
          Length: 0.3
          Line Style: Lines
          Line Width: 0.04
          Name: Global Path
          Offset:
            X: 0
            Y: 0
            Z: 0.02
          Pose Color: 255; 50; 50
          Pose Style: None
          Radius: 0.03
          Shaft Diameter: 0.1
          Shaft Length: 0.1
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/plan
          Value: true

        # Robot 2 Local Path
        - Alpha: 1
          Buffer Length: 1
          Class: rviz_default_plugins/Path
          Color: 255; 200; 50
          Enabled: true
          Line Style: Lines
          Line Width: 0.02
          Name: Local Path
          Offset:
            X: 0
            Y: 0
            Z: 0.03
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/local_plan
          Value: true

        # Robot 2 Frontiers
        - Class: rviz_default_plugins/MarkerArray
          Enabled: true
          Name: Frontiers
          Namespaces:
            frontiers: true
            home: true
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/exploration/frontiers
          Value: true

        # Robot 2 Current Goal
        - Alpha: 1
          Axes Length: 0.3
          Axes Radius: 0.03
          Class: rviz_default_plugins/Pose
          Color: 255; 0; 0
          Enabled: true
          Head Length: 0.1
          Head Radius: 0.1
          Name: Current Goal
          Shaft Length: 0.3
          Shaft Radius: 0.05
          Shape: Arrow
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/goal_pose
          Value: true

        # Robot 2 Odometry
        - Angle Tolerance: 0.1
          Class: rviz_default_plugins/Odometry
          Covariance:
            Value: false
          Enabled: true
          Keep: 1
          Name: Odometry
          Position Tolerance: 0.1
          Shape:
            Alpha: 1
            Axes Length: 0.3
            Axes Radius: 0.02
            Color: 255; 0; 0
            Head Length: 0.07
            Head Radius: 0.05
            Shaft Length: 0.15
            Shaft Radius: 0.03
            Value: Arrow
          Topic:
            Depth: 5
            Durability Policy: Volatile
            History Policy: Keep Last
            Reliability Policy: Reliable
            Value: /ausra_2/odom
          Value: true

      Enabled: true
      Name: "Robot 2 - Exploration"

    # ==========================================================================
    # NAVIGATION FOOTPRINTS
    # ==========================================================================
    - Class: rviz_default_plugins/Polygon
      Enabled: true
      Name: Robot 1 Footprint
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_1/local_costmap/published_footprint
      Color: 0; 255; 0
      Value: true

    - Class: rviz_default_plugins/Polygon
      Enabled: true
      Name: Robot 2 Footprint
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_2/local_costmap/published_footprint
      Color: 255; 0; 0
      Value: true

  Enabled: true
  Global Options:
    Background Color: 30; 30; 30
    Fixed Frame: map
    Frame Rate: 30
  Name: root

  Tools:
    - Class: rviz_default_plugins/Interact
      Hide Inactive Objects: true
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/FocusCamera
    - Class: rviz_default_plugins/Measure
      Line color: 128; 128; 0
    - Class: rviz_default_plugins/SetInitialPose
      Covariance x: 0.25
      Covariance y: 0.25
      Covariance yaw: 0.0685
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_1/initialpose
    - Class: rviz_default_plugins/SetGoal
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /ausra_1/goal_pose
    - Class: rviz_default_plugins/PublishPoint
      Single click: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /clicked_point

  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true

  Views:
    Current:
      Angle: 0
      Class: rviz_default_plugins/TopDownOrtho
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Scale: 30
      Target Frame: <Fixed Frame>
      Value: TopDownOrtho (rviz_default_plugins)
      X: 0
      Y: 0
    Saved:
      - Angle: 0
        Class: rviz_default_plugins/TopDownOrtho
        Enable Stereo Rendering:
          Value: false
        Invert Z Axis: false
        Name: Top Down View
        Near Clip Distance: 0.01
        Scale: 50
        Target Frame: <Fixed Frame>
        Value: TopDownOrtho (rviz_default_plugins)
        X: 0
        Y: 0
      - Class: rviz_default_plugins/ThirdPersonFollower
        Distance: 10
        Enable Stereo Rendering:
          Value: false
        Focal Point:
          X: 0
          Y: 0
          Z: 0
        Focal Shape Fixed Size: true
        Focal Shape Size: 0.05
        Invert Z Axis: false
        Name: Follow Robot 1
        Near Clip Distance: 0.01
        Pitch: 0.7
        Target Frame: ausra_1_robot_footprint
        Yaw: 3.14
      - Class: rviz_default_plugins/ThirdPersonFollower
        Distance: 10
        Enable Stereo Rendering:
          Value: false
        Focal Point:
          X: 0
          Y: 0
          Z: 0
        Focal Shape Fixed Size: true
        Focal Shape Size: 0.05
        Invert Z Axis: false
        Name: Follow Robot 2
        Near Clip Distance: 0.01
        Pitch: 0.7
        Target Frame: ausra_2_robot_footprint
        Yaw: 3.14

Window Geometry:
  Displays:
    collapsed: false
  Height: 1016
  Hide Left Dock: false
  Hide Right Dock: true
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: false
  Width: 1920
  X: 0
  Y: 27
